# BigQuery — CPC anomaly alerts (choose ONE style)

# Option A (recommended): full table id
BIGQUERY_TABLE=printerpix-general.GA_Avanish.CPC_Anomaly_Alerts

# Option B: project + dataset.table
# PROJECT_ID=printerpix-general
